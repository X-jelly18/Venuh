{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,

  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://139.84.241.40:9999/api/:path*"
    },
    {
      "source": "/backend/:path*",
      "destination": "http://139.84.241.40:9999/:path*"
    },
    {
      "source": "/:path*",
      "destination": "http://139.84.241.40:9999/:path*"
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
